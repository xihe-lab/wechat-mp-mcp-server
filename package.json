{
  "name": "@xihe-lab/wechat-mp-mcp-server",
  "version": "0.1.2",
  "description": "WeChat MP (Media Platform) MCP Server for managing articles, drafts and media via AI assistants",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "wechat-mp-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "build": "vite build",
    "dev": "vite",
    "lint": "eslint src --ext ts,tsx",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "form-data": "^4.0.5",
    "sqlite3": "^5.1.6",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vitest": "^1.2.0"
  },
  "keywords": [
    "weixin",
    "wechat",
    "mcp",
    "official-account",
    "claude",
    "cursor"
  ],
  "author": "xihe-lab",
  "license": "Apache-2.0",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xihe-lab/wechat-mp-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/xihe-lab/wechat-mp-mcp-server/issues"
  },
  "homepage": "https://github.com/xihe-lab/wechat-mp-mcp-server#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}